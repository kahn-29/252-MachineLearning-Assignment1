 {\".jpg\", \".jpeg\", \".png\"}\n","records = []\n","\n","for root, _, files in os.walk(path):\n","    folder = os.path.basename(root).lower()\n","    if \"cat\" in folder: label_str = \"cat\"\n","    elif \"dog\" in folder: label_str = \"dog\"\n","    else: continue\n","\n","    for fname in files:\n","        if Path(fname).suffix.lower() in VALID_EXT:\n","            records.append({\n","                \"path\":  os.path.join(root, fname),\n","                \"label\": label_str,\n","            })\n","\n","df = pd.DataFrame(records)\n","df.insert(0, \"id\", range(len(df)))\n","\n","# Label encoding\n","le = LabelEncoder()\n","df[\"label_encoded\"] = le.fit_transform(df[\"label\"])\n","\n","print(\"Class mapping:\", dict(zip(le.classes_, le.transform(le.classes_))))\n","print(f\"DataFrame shape: {df.shape}\")\n","display(df.head(8))"]},{"cell_type":"code","source":["def savefig(name):\n","    path = DIRS[\"figures\"] / name\n","    plt.tight_layout()\n","    plt.savefig(path, dpi=160, bbox_inches=\"tight\")\n","    print(\"Saved:\", path)\n","\n","def infer_label(path):\n","    parts = [p.lower() for p in Path(path).parts]\n","    name = Path(path).name.lower()\n","    if \"cats\" in parts or \"cat\" in parts or name.startswith(\"cat\"):\n","        return 0, \"Cat\"\n","    if \"dogs\" in parts or \"dog\" in parts or name.startswith(\"dog\"):\n","        return 1, \"Dog\"\n","    return None, None\n","\n","def collect_images(root):\n","    exts = tuple(e.lower() for e in CONFIG[\"dataset\"][\"image_extensions\"])\n","    records = []\n","    for p in Path(root).rglob(\"*\"):\n","        if p.suffix.lower() in exts:\n","            label, label_name = infer_label(str(p))\n","            if label is not None:\n","                records.append({\"path\": str(p), \"label\": label, \"label_name\": label_name})\n","    return pd.DataFrame(records).drop_duplicates(\"path\").reset_index(drop=True)\n","\n","def show_image_grid(df, title, filename, n_per_class=5):\n",